# Database Configuration
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/nutritheous
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=your_password_here

# OpenAI-compatible Vision backend
# Option A: LM Studio (local/remote OpenAI-compatible server)
# OPENAI_API_KEY=lm-studio
# OPENAI_BASE_URL=http://100.81.65.74:1234/v1
# OPENAI_API_MODEL=qwen/qwen3-vl-8b

# Option B: OpenRouter / OpenAI cloud
OPENAI_API_KEY=sk-or-v1-your-key-here
OPENAI_API_URL=https://openrouter.ai/api/v1/chat/completions
OPENAI_API_MODEL=anthropic/claude-3.5-sonnet

# Max tokens for nutrition vision analysis
OPENAI_API_MAX_TOKENS=800
OPENAI_API_TIMEOUT=30

# Server Configuration
SERVER_PORT=8081

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-make-it-long-and-random
JWT_EXPIRATION=86400000

# Google Maps API (Optional - for location context)
# Get key from: https://console.cloud.google.com/
GOOGLE_MAPS_API_KEY=your_google_maps_key_here

# CORS (for local Flutter development)
CORS_ALLOWED_ORIGINS=http://localhost:*,http://192.168.*:*
